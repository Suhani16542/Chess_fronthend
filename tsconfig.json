{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,

    /* Strict type-checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": false,

    /* Module */
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* JSX */
    "jsx": "react-jsx",

    /* Build */
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],

    /* Path aliases */
    "paths": {
      "@/*":             ["./src/*"],
      "@/components/*":  ["./src/components/*"],
      "@/lib/*":         ["./src/lib/*"],
      "@/hooks/*":       ["./src/hooks/*"],
      "@/types/*":       ["./src/types/*"],
      "@/data/*":        ["./src/data/*"],
      "@/styles/*":      ["./src/styles/*"],
      "@/assets/*":      ["./src/assets/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
